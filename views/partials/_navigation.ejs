<header class="top-navbar">
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="" /></a>
            <div class="collapse navbar-collapse" id="navbars-rs-food">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/courses">Courses</a></li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <% if(!userIN) { %>
                        <li><a class="hover-btn-new log" href="#" data-toggle="modal" data-target="#login"><span>Login</span></a></li>
                        <li><a class="hover-btn-new log" href="#" data-toggle="modal" data-target="#register"><span>Register</span></a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/users/logout" style="color: #ffa200 !important; font-weight: bold;"><span>LOGOUT</span></a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="modal fade" id="login" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body customer-box">
                <h4 class="text-center">LOGIN</h4>
                <form method="POST" action="/users/login">
                    <div class="form-group"><input class="form-control" name="email" placeholder="Email" type="email" required></div>
                    <div class="form-group"><input class="form-control" name="password" placeholder="Password" type="password" required></div>
                    <button type="submit" class="btn btn-light btn-radius btn-brd grd1">SUBMIT</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="register" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body customer-box">
                <h4 class="text-center">REGISTER</h4>
                <form method="POST" action="/users/signup">
                    <div class="form-group"><input class="form-control" name="name" placeholder="Name" type="text" required></div>
                    <div class="form-group"><input class="form-control" name="email" placeholder="Email" type="email" required></div>
                    <div class="form-group"><input class="form-control" name="password" placeholder="Password" type="password" required></div>
                    <button type="submit" class="btn btn-light btn-radius btn-brd grd1">SAVE & CONTINUE</button>
                </form>
            </div>
        </div>
    </div>
</div>